# ─── Formspree ────────────────────────────────────────────────────────────────
# Create a free account at https://formspree.io and grab your form ID.
# Example: https://formspree.io/f/xyzabcde → FORMSPREE_ID=xyzabcde
NEXT_PUBLIC_FORMSPREE_ID=your_formspree_form_id

# ─── WhatsApp ─────────────────────────────────────────────────────────────────
# Full international number without +, spaces or dashes.
# Dominican Republic example: 18091234567
NEXT_PUBLIC_WHATSAPP_NUMBER=18491234567

# ─── Site metadata ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://webuildmedia.com
